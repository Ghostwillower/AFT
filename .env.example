# --- The Gym Group credentials (any valid membership can read occupancy) ---
# Leave these blank to run in DEMO MODE with realistic synthetic data.
GYM_GROUP_EMAIL=
GYM_GROUP_PIN=

# --- Which gym to track ---
# By default the app finds the gym whose name contains this text.
GYM_NAME_QUERY=Chelmsford
# Optionally pin the exact gym location UUID (skips name lookup):
# GYM_LOCATION_ID=

# --- Recording / server ---
POLL_INTERVAL_MINUTES=15
PORT=3000
# DB_PATH=./data/occupancy.db
